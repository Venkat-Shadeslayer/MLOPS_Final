# Copy this file to .env. .env is git-ignored.

# ============================================================================
# Postgres (shared instance, separate DBs)
# ============================================================================
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops_local_dev_pw
POSTGRES_DB=mlops
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

AIRFLOW_DB=airflow
PREDICTIONS_DB=predictions
MLFLOW_DB=mlflow

# ============================================================================
# MLflow
# ============================================================================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://mlops:mlops_local_dev_pw@postgres:5432/mlflow
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts
MLFLOW_EXPERIMENT=aqi_regression

# ============================================================================
# Airflow
# ============================================================================
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://mlops:mlops_local_dev_pw@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session
AIRFLOW_UID=50000

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# ============================================================================
# FastAPI
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
MODEL_NAME=aqi_regressor
MODEL_STAGE=Production

# ============================================================================
# Streamlit
# ============================================================================
STREAMLIT_API_URL=http://api:8000
STREAMLIT_MLFLOW_URL=http://localhost:5001
STREAMLIT_AIRFLOW_URL=http://localhost:8080
STREAMLIT_GRAFANA_URL=http://localhost:3000

# ============================================================================
# Monitoring
# ============================================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================================
# Drift / retraining
# ============================================================================
DRIFT_RMSE_THRESHOLD=15.0
DRIFT_ERROR_RATE_THRESHOLD=0.05
DRIFT_CHECK_WINDOW_HOURS=24
DRIFT_PSI_THRESHOLD=0.2