airflow/airflow.db
airflow/airflow.cfg
airflow/webserver_config.py
airflow/standalone_admin_password.txt

# Docker persistent volumes
.docker-volumes/

# Secrets — NEVER commit
.env
*.pem
kaggle.json
secrets/

